{
  "name": "flash-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "asbuild": "asc assembly/index.ts --target release --outFile public/wasm/thumb.wasm --optimize",
    "asbuild:debug": "asc assembly/index.ts --target debug --outFile public/wasm/thumb.wasm",
    "dev": "npm run asbuild && vite",
    "build": "npm run asbuild && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "assemblyscript": "^0.27.31",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
